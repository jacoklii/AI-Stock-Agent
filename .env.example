# Copy to .env and fill in. Never commit .env.

# --- Postgres (consumed by docker-compose and the backend) ---
POSTGRES_USER=stockagent
POSTGRES_PASSWORD=stockagent
POSTGRES_DB=stockagent
POSTGRES_PORT=5432

# Async SQLAlchemy / asyncpg URL the backend connects with.
# Host is localhost when the app runs on the host and Postgres runs via docker-compose.
DATABASE_URL=postgresql+asyncpg://stockagent:stockagent@localhost:5432/stockagent

# --- Embeddings (FIXED model; changing it is an explicit backfill) ---
# The model name is stored alongside every vector so a swap is detectable.
EMBEDDING_MODEL=voyage-3
EMBEDDING_DIM=1024
VOYAGE_API_KEY=PLACEHOLDER

# --- LLM (Anthropic) — the researcher agent's synthesis + summarization ---
ANTHROPIC_API_KEY=PLACEHOLDER

# --- News provider (Finnhub, free tier) ---
FINNHUB_API_KEY=PLACEHOLDER

# --- Breadth automation ---
# Start the in-process APScheduler in the API lifespan. Off in dev/tests so nothing fires
# external-API jobs; the always-on host sets true to run ingest/digest/brief/research on schedule.
ENABLE_SCHEDULER=false

# --- Notifier ---
# Email (detailed digest) via SMTP.
SMTP_HOST=PLACEHOLDER
SMTP_PORT=587
SMTP_USER=PLACEHOLDER
SMTP_PASSWORD=PLACEHOLDER
SMTP_FROM=PLACEHOLDER
# Brief pulse goes to iMessage (AppleScript on a macOS host) or WhatsApp; recipient
# addresses live on UserPreferences.channels (seeded), not here.
