# Copy to .env and fill in. Never commit .env.

# --- Postgres (consumed by docker-compose and the backend) ---
POSTGRES_USER=stockagent
POSTGRES_PASSWORD=stockagent
POSTGRES_DB=stockagent
POSTGRES_PORT=5432

# Async SQLAlchemy / asyncpg URL the backend connects with.
# Host is localhost when the app runs on the host and Postgres runs via docker-compose.
DATABASE_URL=postgresql+asyncpg://stockagent:stockagent@localhost:5432/stockagent

# --- Embeddings (FIXED model; changing it is an explicit backfill) ---
# The model name is stored alongside every vector so a swap is detectable.
EMBEDDING_MODEL=voyage-3
EMBEDDING_DIM=1024
VOYAGE_API_KEY=
